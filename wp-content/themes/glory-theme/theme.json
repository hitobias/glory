{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "color": {
      "palette": [
        { "slug": "primary-500", "color": "#2872fa", "name": "Primary" },
        { "slug": "primary-600", "color": "#1a5ce0", "name": "Primary Dark" },
        { "slug": "primary-100", "color": "#d9e6ff", "name": "Primary Light" },
        { "slug": "primary-50", "color": "#eef4ff", "name": "Primary Lightest" },
        { "slug": "accent", "color": "#fcc800", "name": "Accent Yellow" },
        { "slug": "accent-50", "color": "#fffce5", "name": "Accent Lightest" },
        { "slug": "accent-100", "color": "#fff8c2", "name": "Accent Light" },
        { "slug": "accent-400", "color": "#fcd419", "name": "Accent Hover" },
        { "slug": "accent-800", "color": "#89560a", "name": "Accent Dark" },
        { "slug": "accent-green", "color": "#195630", "name": "Accent Green" },
        { "slug": "accent-green-100", "color": "#dcfce7", "name": "Accent Green Light" },
        { "slug": "accent-green-800", "color": "#195630", "name": "Accent Green Dark" },
        { "slug": "dark", "color": "#192a3d", "name": "Dark" },
        { "slug": "dark-300", "color": "#95b8d7", "name": "Dark 300" },
        { "slug": "dark-400", "color": "#6394c2", "name": "Dark 400" },
        { "slug": "dark-500", "color": "#4077ad", "name": "Dark 500" },
        { "slug": "dark-700", "color": "#294d77", "name": "Dark 700" },
        { "slug": "white", "color": "#ffffff", "name": "White" }
      ],
      "custom": false,
      "defaultPalette": false
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "\"Noto Sans TC\", Roboto, \"Open Sans\", ui-sans-serif, system-ui, sans-serif",
          "slug": "glory-sans",
          "name": "Glory Sans"
        }
      ],
      "fontSizes": [
        { "slug": "small", "size": "0.875rem", "name": "小" },
        { "slug": "medium", "size": "1rem", "name": "中" },
        { "slug": "large", "size": "1.125rem", "name": "大" },
        { "slug": "x-large", "size": "1.25rem", "name": "特大" },
        { "slug": "xx-large", "size": "1.5rem", "name": "超大" }
      ]
    },
    "spacing": {
      "units": ["px", "em", "rem", "%", "vw"]
    },
    "layout": {
      "contentSize": "75rem",
      "wideSize": "90rem"
    },
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true
  },
  "styles": {
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--glory-sans)",
      "fontSize": "1rem",
      "lineHeight": "1.75"
    },
    "color": {
      "background": "#ffffff",
      "text": "#192a3d"
    },
    "elements": {
      "link": {
        "color": {
          "text": "#2872fa"
        },
        ":hover": {
          "color": {
            "text": "#1548b8"
          }
        }
      },
      "heading": {
        "color": {
          "text": "#192a3d"
        },
        "typography": {
          "fontWeight": "600"
        }
      },
      "h1": {
        "typography": {
          "fontSize": "2.5rem",
          "lineHeight": "1.3"
        }
      },
      "h2": {
        "typography": {
          "fontSize": "2rem",
          "lineHeight": "1.35"
        }
      },
      "h3": {
        "typography": {
          "fontSize": "1.5rem",
          "lineHeight": "1.4"
        }
      },
      "h4": {
        "typography": {
          "fontSize": "1.25rem",
          "lineHeight": "1.5"
        }
      }
    },
    "blocks": {
      "core/button": {
        "border": {
          "radius": "8px"
        },
        "typography": {
          "fontWeight": "600"
        }
      },
      "core/quote": {
        "border": {
          "left": {
            "color": "#2872fa",
            "width": "4px",
            "style": "solid"
          }
        }
      }
    }
  }
}
